ANTHROPIC_API_KEY=sk-ant-...
KV_REST_API_URL=https://your-store.upstash.io
KV_REST_API_TOKEN=...
# Neon Postgres (separate project from Testerify) — backs the /ask assistant's knowledge
DATABASE_URL=postgres://user:pass@ep-xxx.neon.tech/alp-portfolio?sslmode=require
# Shared secret for the nightly /api/refresh-knowledge cron (Vercel sends it as a Bearer token)
CRON_SECRET=...
# Resend — powers the contact form (/api/contact). testerify.com is verified in Resend.
RESEND_API_KEY=re_...
# Optional overrides; both default to alp@testerify.com. FROM must be on a verified domain.
# CONTACT_TO_EMAIL=alp@testerify.com
# CONTACT_FROM_EMAIL=Alp Senel <alp@testerify.com>
