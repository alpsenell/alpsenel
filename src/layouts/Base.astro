---
import type { Lang } from '../i18n/strings';
import { strings } from '../i18n/strings';
import { loadKnowledge } from '../lib/knowledgeStore';
import AskHero from '../components/AskHero.astro';
import ContactForm from '../components/ContactForm.astro';

interface Props {
  lang: Lang;
  /** Path of THIS page relative to the site root, e.g. '/' or '/tr/'. */
  path: string;
}

const { lang, path } = Astro.props;
const t = strings[lang];

// Real-time: projects + contact come from the Neon store (falls back to the
// static defaults if the DB is unset/unreachable). Requires this page to be
// server-rendered — see `export const prerender = false` in the route files.
const { projects, contactEmail } = await loadKnowledge();

const site = 'https://alpsenel.com';
const canonical = new URL(path, site).href;
const enUrl = new URL('/', site).href;
const trUrl = new URL('/tr/', site).href;
const ogImage = new URL('/og.png', site).href;

// Person + WebSite structured data — the name lives here for search engines,
// even though it is intentionally never shown in the visible page body.
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': `${site}/#person`,
      name: 'Alp Senel',
      url: site,
      jobTitle: lang === 'tr' ? 'Web Geliştirici & Tasarımcı' : 'Web Developer & Designer',
      knowsAbout: ['Web Development', 'Web Design', 'E-commerce', 'Shopify', 'Frontend Engineering'],
      // sameAs ties this site to the same real-world person across the web —
      // the strongest signal for ranking on the name "Alp Senel".
      sameAs: [
        'https://www.linkedin.com/in/alpsenel',
        'https://github.com/alpsenell',
        'https://www.instagram.com/alpsenel/',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${site}/#website`,
      url: site,
      name: 'Alp Senel',
      inLanguage: t.htmlLang,
      publisher: { '@id': `${site}/#person` },
    },
  ],
};

// Per-language project payload for the client (powers the "window" modal).
const clientProjects = projects.map((p) => ({
  num: p.num,
  name: p.name,
  year: p.year,
  url: p.url,
  handle: p.handle,
  tech: p.tech,
  brief: p.brief[lang],
}));
---

<!DOCTYPE html>
<html lang={t.htmlLang} data-theme="dark" data-accent="lime">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{t.title}</title>
  <meta name="description" content={t.description} />
  <meta name="author" content="Alp Senel" />
  <link rel="canonical" href={canonical} />

  <!-- hreflang: tell Google about both language versions -->
  <link rel="alternate" hreflang="en" href={enUrl} />
  <link rel="alternate" hreflang="tr" href={trUrl} />
  <link rel="alternate" hreflang="x-default" href={enUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Alp Senel" />
  <meta property="og:title" content={t.title} />
  <meta property="og:description" content={t.description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content={t.ogLocale} />
  <meta property="og:locale:alternate" content={t.ogLocaleAlt} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={t.title} />
  <meta name="twitter:description" content={t.description} />
  <meta name="twitter:image" content={ogImage} />

  <meta name="theme-color" content="#0c0e12" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/favicon.svg" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  />

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Testerify -->
  <script
    is:inline
    src="https://panel.testerify.com/testerify.js"
    data-tfy-key="0002456bd0a99b4e2ef2a6d37ff5dd537499ba1f81b83d415fb4654e87e6231d"
    defer
  ></script>

  <!-- Testerify custom-event tracking. One global helper + delegated click
       listener: any element carrying `data-tfy-event` fires that event. The
       two forms call window.tfyEvent() from their own handlers so keyboard
       submits are counted too. Defined here so it exists before any inline
       component script runs; the Testerify SDK above loads `defer`, so the
       guard tolerates clicks that land before the SDK is ready. -->
  <script is:inline>
    window.tfyEvent = function (name) {
      if (!name) return;
      try {
        var t = window.testerify;
        if (t && typeof t.customEvent === 'function') t.customEvent(name);
      } catch (e) {
        /* analytics must never break the page */
      }
    };
    document.addEventListener(
      'click',
      function (e) {
        var node = e.target;
        if (!(node instanceof Element)) return;
        var el = node.closest('[data-tfy-event]');
        if (el) window.tfyEvent(el.getAttribute('data-tfy-event'));
      },
      true
    );
  </script>
</head>
<body>
  <div class="screen">
    <canvas id="ripplecanvas"></canvas>
    <div id="curring"></div>
    <div id="curdot"></div>

    <div class="layer">
      <!-- top bar -->
      <header class="topbar">
        <span class="brand">{t.brand}</span>
        <div class="topbar-actions">
          <a class="lang" data-cursor data-tfy-event="lang_toggle" href={t.otherLangHref} hreflang={lang === 'en' ? 'tr' : 'en'} aria-label="Change language">{t.otherLangLabel}</a>
          <button data-cursor data-tfy-event="theme_toggle" id="themeToggle" aria-label="Toggle theme">
            <span class="dot"></span><span id="themeLabel">{t.lightsOn}</span>
          </button>
        </div>
      </header>

      <!-- HERO -->
      <section class="hero">
        <div class="hero-row">
          <div class="hero-head">
            <!-- Real page heading for search engines & screen readers.
                 Visually hidden (accessible pattern, not display:none) so the
                 hero's visual focus stays on the "ask" prompt. -->
            <h1 class="visually-hidden">{t.title}</h1>
            <AskHero lang={lang} />
          </div>
          <aside class="hero-meta">
            <div>
              <div class="meta-label">{t.metaBasedLabel}</div>
              <div class="meta-value">{t.metaBasedValue}</div>
            </div>
            <div>
              <div class="meta-label">{t.metaChannelLabel}</div>
              <a class="meta-link" data-cursor data-tfy-event="contact_mailto" href={`mailto:${contactEmail}`}>{t.signal}</a>
            </div>
          </aside>
        </div>
        <a class="scroll-explore" data-cursor data-tfy-event="scroll_to_work" href="#work">
          {t.scrollLabel}
          <span class="chevrons"><span></span><span></span><span></span></span>
        </a>
      </section>

      <!-- INDEX -->
      <section id="work" class="index">
        <div class="label">{t.workLabel}</div>
        {projects.map((p, i) => (
          <a class="entry" href={p.url} target="_blank" rel="noopener" data-cursor data-reveal data-index={i} data-tfy-event={`project_open_${p.handle}`}>
            <span class="left">
              <span class="num">{p.num}</span>
              <span class="name">{p.name}</span>
            </span>
            <span class="year">{p.year} ↗</span>
          </a>
        ))}
      </section>

      <!-- CHANNEL -->
      <section class="channel">
        <div class="label">{t.channelLabel}</div>
        <ContactForm lang={lang} />
        <div class="signed">
          <span class="lbl">{t.signed}</span>
          <span class="cipher" id="cipher">█▓█▓██▓█▓</span>
        </div>
      </section>

      <footer class="site">
        <span>{t.footLeft}</span>
        <span>{t.footRight}</span>
      </footer>
    </div>
  </div>

  <!-- project "window" — full-page animated takeover -->
  <div id="proj-window" class="fullwin" role="dialog" aria-modal="true" aria-labelledby="fw-name" aria-hidden="true">
    <canvas id="winripple" class="fw-canvas"></canvas>
    <div class="fw-bar">
      <span class="win-dots"><i></i><i></i><i></i></span>
      <span class="fw-addr" id="fw-addr">anon://</span>
      <button class="fw-close" data-close type="button" data-tfy-event="project_close" aria-label={t.closeLabel}>{t.closeLabel} ✕</button>
    </div>
    <div class="fw-inner">
      <div class="fw-meta"><span id="fw-num"></span><span id="fw-year"></span></div>
      <h2 class="fw-name" id="fw-name"></h2>
      <p class="fw-brief" id="fw-brief"></p>
      <div class="fw-stack-label">{t.stackLabel}</div>
      <div class="fw-stack" id="fw-stack"></div>
      <a class="fw-open" id="fw-open" href="#" target="_blank" rel="noopener" data-tfy-event="project_open_live">{t.openLive}</a>
    </div>
  </div>

  <script type="application/json" id="projects-data" set:html={JSON.stringify(clientProjects)} />

  <script
    is:inline
    define:vars={{ lightsOn: t.lightsOn, lightsOff: t.lightsOff }}
  >
    // ---- theme toggle ----
    (function () {
      const root = document.documentElement;
      const label = document.getElementById('themeLabel');
      const syncLabel = function () {
        label.textContent = root.getAttribute('data-theme') === 'dark' ? lightsOn : lightsOff;
      };
      syncLabel();
      document.getElementById('themeToggle').addEventListener('click', function () {
        root.setAttribute('data-theme', root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
        syncLabel();
      });

      // ---- project "window" — full-page animated takeover ----
      (function () {
        const win = document.getElementById('proj-window');
        const dataEl = document.getElementById('projects-data');
        if (!win || !dataEl) return;
        let data = [];
        try { data = JSON.parse(dataEl.textContent); } catch (e) { return; }

        const elNum = document.getElementById('fw-num');
        const elYear = document.getElementById('fw-year');
        const elName = document.getElementById('fw-name');
        const elAddr = document.getElementById('fw-addr');
        const elBrief = document.getElementById('fw-brief');
        const elStack = document.getElementById('fw-stack');
        const elOpen = document.getElementById('fw-open');
        let lastFocus = null;

        function open(idx, ox, oy) {
          const p = data[idx];
          if (!p) return;
          elNum.textContent = p.num;
          elYear.textContent = p.year;
          elName.textContent = p.name;
          elAddr.textContent = 'anon://' + p.handle;
          elBrief.textContent = p.brief;
          elOpen.href = p.url;
          elStack.innerHTML = '';
          p.tech.forEach(function (techName) {
            const chip = document.createElement('span');
            chip.className = 'fw-chip';
            chip.textContent = techName;
            elStack.appendChild(chip);
          });
          // grow a circle open from the exact click point, large enough to cover the viewport
          const vw = window.innerWidth, vh = window.innerHeight;
          const r = Math.hypot(Math.max(ox, vw - ox), Math.max(oy, vh - oy));
          win.style.setProperty('--ox', ox + 'px');
          win.style.setProperty('--oy', oy + 'px');
          win.style.setProperty('--r', Math.ceil(r) + 'px');
          win.scrollTop = 0;
          win.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';
          lastFocus = document.activeElement;
          win.getBoundingClientRect(); // flush styles so the transition runs
          requestAnimationFrame(function () { win.classList.add('open'); });
          setTimeout(function () { elOpen.focus(); }, 80);
        }
        function close() {
          win.classList.remove('open');
          win.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
          if (lastFocus && lastFocus.focus) lastFocus.focus();
        }

        document.querySelectorAll('.index .entry').forEach(function (el) {
          el.addEventListener('click', function (e) {
            // let modified clicks (new tab / middle) fall through to the real link
            if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey || e.button !== 0) return;
            e.preventDefault();
            const rect = el.getBoundingClientRect();
            const ox = e.clientX || rect.left + rect.width / 2;
            const oy = e.clientY || rect.top + rect.height / 2;
            open(parseInt(el.getAttribute('data-index'), 10), ox, oy);
          });
        });
        win.querySelectorAll('[data-close]').forEach(function (el) {
          el.addEventListener('click', close);
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && win.classList.contains('open')) close();
        });
      })();

      // ---- self-scrambling signature — never resolves ----
      const charset = '█▓▒░#@%&$?/\\*+=<>0123456789ABCDEFGHJKLMNPQRSTUVWXYZ'.split('');
      const cipherEl = document.getElementById('cipher');
      setInterval(function () {
        let s = '';
        for (let i = 0; i < 11; i++) s += charset[Math.floor(Math.random() * charset.length)];
        cipherEl.textContent = s;
      }, 110);

      // ---- scroll reveal ----
      (function () {
        const els = document.querySelectorAll('[data-reveal]');
        els.forEach(function (el) {
          el.style.opacity = '0';
          el.style.transform = 'translateY(26px)';
          el.style.transition = 'opacity .8s ease, transform .8s ease';
        });
        if ('IntersectionObserver' in window) {
          const io = new IntersectionObserver(function (ents) {
            ents.forEach(function (e) {
              if (e.isIntersecting) {
                e.target.style.opacity = '1';
                e.target.style.transform = 'none';
                io.unobserve(e.target);
              }
            });
          }, { threshold: 0.2 });
          els.forEach(function (el) { io.observe(el); });
          setTimeout(function () {
            els.forEach(function (el) { el.style.opacity = '1'; el.style.transform = 'none'; });
          }, 2600);
        } else {
          els.forEach(function (el) { el.style.opacity = '1'; el.style.transform = 'none'; });
        }
      })();

      // ---- cursor follow + water-surface ripple FX ----
      // A height-field water simulation (damped wave equation). Pointer moves
      // and clicks drop disturbances that spread, interfere and fade like
      // ripples on a dark pool, lit from the top-left with an accent sheen.
      (function () {
        const canvas = document.getElementById('ripplecanvas');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        const host = document.querySelector('.screen');
        const dot = document.getElementById('curdot');
        const ring = document.getElementById('curring');
        const fine = window.matchMedia('(pointer:fine)').matches;
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        const SCALE = 6;      // px per simulation cell
        const DAMP = 0.967;   // wave energy retained per frame (higher = waves travel further)
        let cols, rows, cur, prev, off, offCtx, img, accent = [163, 230, 53], winCanvas, winCtx;
        const fwEl = document.getElementById('proj-window');

        function resolveAccent() {
          try {
            offCtx.fillStyle = getComputedStyle(host).getPropertyValue('--accent').trim() || '#a3e635';
            offCtx.fillRect(0, 0, 1, 1);
            const d = offCtx.getImageData(0, 0, 1, 1).data;
            accent = [d[0], d[1], d[2]];
          } catch (e) {}
        }

        function setup() {
          cols = Math.max(8, Math.ceil(window.innerWidth / SCALE));
          rows = Math.max(8, Math.ceil(window.innerHeight / SCALE));
          cur = new Float32Array(cols * rows);
          prev = new Float32Array(cols * rows);
          off = document.createElement('canvas');
          off.width = cols; off.height = rows;
          offCtx = off.getContext('2d', { willReadFrequently: true });
          img = offCtx.createImageData(cols, rows);
          canvas.width = window.innerWidth; canvas.height = window.innerHeight;
          canvas.style.width = window.innerWidth + 'px'; canvas.style.height = window.innerHeight + 'px';
          winCanvas = document.getElementById('winripple');
          winCtx = winCanvas ? winCanvas.getContext('2d') : null;
          if (winCanvas) { winCanvas.width = window.innerWidth; winCanvas.height = window.innerHeight; }
          resolveAccent();
        }
        setup();
        window.addEventListener('resize', setup);

        // drop a soft, radius-stamped disturbance so the rings stay circular
        function drop(px, py, power) {
          const cx = Math.round(px / SCALE), cy = Math.round(py / SCALE), rad = 2;
          for (let y = -rad; y <= rad; y++) {
            for (let x = -rad; x <= rad; x++) {
              const gx = cx + x, gy = cy + y;
              if (gx < 1 || gy < 1 || gx >= cols - 1 || gy >= rows - 1) continue;
              const d = Math.sqrt(x * x + y * y);
              if (d > rad) continue;
              prev[gy * cols + gx] -= power * (1 - d / rad);
            }
          }
        }

        // ---- cursor dot + ring follow ----
        let mx = window.innerWidth / 2, my = window.innerHeight / 2, rx = mx, ry = my, lx = mx, ly = my;
        let hover = false;

        // ---- magnetic headline: split words into per-character spans ----
        let pointerMoved = false;
        const headEl = document.querySelector('[data-head]');
        const magChars = [];
        if (headEl) headEl.querySelectorAll('[data-word]').forEach(function (w) {
          const isAccent = w.hasAttribute('data-accent');
          w.style.display = 'inline-block'; w.style.whiteSpace = 'nowrap';
          const text = w.textContent; w.textContent = '';
          for (const ch of text) {
            const isSpace = (ch === ' ' || ch === ' ');
            const s = document.createElement('span');
            s.textContent = isSpace ? ' ' : ch;
            s.style.display = 'inline-block';
            s.style.willChange = 'transform';
            if (isAccent) s.style.color = 'var(--accent)';
            w.appendChild(s);
            magChars.push({ el: s, tx: 0, ty: 0 });
          }
        });
        if (fine) {
          host.style.cursor = 'none';
          if (dot) dot.style.opacity = '1';
          if (ring) ring.style.opacity = '1';
        }
        window.addEventListener('pointermove', function (e) {
          mx = e.clientX; my = e.clientY;
          pointerMoved = true;
          if (dot) dot.style.transform = 'translate(' + mx + 'px,' + my + 'px)';
          const dx = mx - lx, dy = my - ly, dist2 = dx * dx + dy * dy;
          if (dist2 > 90) { drop(mx, my, Math.min(1.3 + dist2 * 0.0012, 3.8)); lx = mx; ly = my; }
        }, { passive: true });
        window.addEventListener('pointerdown', function (e) { drop(e.clientX, e.clientY, 9); }, { passive: true });

        document.querySelectorAll('[data-cursor]').forEach(function (el) {
          el.addEventListener('pointerenter', function () { hover = true; });
          el.addEventListener('pointerleave', function () { hover = false; });
        });

        // gentle ambient drips so the surface always breathes
        let ambient = 60;
        function maybeAmbient() {
          if (reduce) return;
          if (--ambient <= 0) {
            ambient = 80 + Math.floor(Math.random() * 120);
            drop(Math.random() * window.innerWidth, Math.random() * window.innerHeight, 2.0);
          }
        }

        function tick() {
          rx += (mx - rx) * 0.16; ry += (my - ry) * 0.16;
          if (ring) ring.style.transform = 'translate(' + rx + 'px,' + ry + 'px) scale(' + (hover ? 2.2 : 1) + ')';

          // magnetic headline — recompute centers each frame so it survives scroll
          if (pointerMoved && magChars.length) {
            const R = 220, MK = 1.5;
            for (let m = 0; m < magChars.length; m++) {
              const c = magChars[m];
              const b = c.el.getBoundingClientRect();
              const ccx = b.left + b.width / 2, ccy = b.top + b.height / 2;
              let tx = 0, ty = 0;
              const ddx = mx - (ccx - c.tx), ddy = my - (ccy - c.ty), dd = Math.hypot(ddx, ddy);
              if (dd < R) { const ff = 1 - dd / R; tx = ddx * ff * 0.4 * MK; ty = ddy * ff * 0.4 * MK; }
              c.tx += (tx - c.tx) * 0.18; c.ty += (ty - c.ty) * 0.18;
              const sc = Math.min(1 + Math.hypot(c.tx, c.ty) / 60, 1.45);
              c.el.style.transform = 'translate(' + c.tx + 'px,' + c.ty + 'px) scale(' + sc + ')';
            }
          }

          maybeAmbient();

          // propagate the wave field
          for (let y = 1; y < rows - 1; y++) {
            const r = y * cols;
            for (let x = 1; x < cols - 1; x++) {
              const i = r + x;
              cur[i] = ((prev[i - 1] + prev[i + 1] + prev[i - cols] + prev[i + cols]) * 0.5 - cur[i]) * DAMP;
            }
          }
          const tmp = cur; cur = prev; prev = tmp; // prev now holds the newest field

          // render height field as light on water
          const data = img.data, ar = accent[0], ag = accent[1], ab = accent[2];
          for (let y = 1; y < rows - 1; y++) {
            const r = y * cols;
            for (let x = 1; x < cols - 1; x++) {
              const i = r + x;
              const h = prev[i];
              const spec = Math.max(0, (prev[i - 1] - prev[i + 1]) * 0.7 + (prev[i - cols] - prev[i + cols]) * 0.9);
              let a = Math.abs(h) * 62 + spec * 46; if (a > 255) a = 255;
              let sp = spec * 150; if (sp > 255) sp = 255;
              const p = i * 4;
              data[p] = ar + sp > 255 ? 255 : ar + sp;
              data[p + 1] = ag + sp > 255 ? 255 : ag + sp;
              data[p + 2] = ab + sp > 255 ? 255 : ab + sp;
              data[p + 3] = a;
            }
          }
          offCtx.putImageData(img, 0, 0);
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          ctx.imageSmoothingEnabled = true;
          ctx.drawImage(off, 0, 0, canvas.width, canvas.height);

          // mirror the same water field inside the open project window
          if (winCtx && fwEl && fwEl.classList.contains('open')) {
            winCtx.clearRect(0, 0, winCanvas.width, winCanvas.height);
            winCtx.imageSmoothingEnabled = true;
            winCtx.drawImage(off, 0, 0, winCanvas.width, winCanvas.height);
          }

          requestAnimationFrame(tick);
        }
        tick();
      })();
    })();
  </script>

  <style is:global>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    /* Accessible "visually hidden": kept in the accessibility tree and read by
       search engines, but off-screen for sighted users. NOT display:none. */
    .visually-hidden { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0; }
    :root {
      --bg: oklch(0.155 0.012 256); --bg2: oklch(0.205 0.013 256);
      --line: oklch(0.30 0.012 256); --fg: oklch(0.965 0.004 256); --fg2: oklch(0.66 0.012 256); --fg3: oklch(0.46 0.012 256);
      --accent: oklch(0.87 0.17 132); --ink: oklch(0.16 0.02 256);
    }
    [data-theme="light"] {
      --bg: oklch(0.975 0.004 256); --bg2: oklch(0.945 0.006 256);
      --line: oklch(0.88 0.006 256); --fg: oklch(0.205 0.013 256); --fg2: oklch(0.46 0.012 256); --fg3: oklch(0.64 0.01 256);
    }
    [data-accent="cyan"] { --accent: oklch(0.83 0.13 218); }
    [data-accent="violet"] { --accent: oklch(0.78 0.15 292); }
    [data-accent="coral"] { --accent: oklch(0.77 0.16 32); }
    body { background: var(--bg); color: var(--fg); font-family: 'Space Grotesk', sans-serif; -webkit-font-smoothing: antialiased; }
    ::selection { background: var(--accent); color: var(--ink); }
    @keyframes blink { 0%, 100% { opacity: .4; } 50% { opacity: 1; } }
    @keyframes chevFall { 0% { opacity: 0; transform: translateY(-5px) rotate(45deg); } 50% { opacity: 1; } 100% { opacity: 0; transform: translateY(5px) rotate(45deg); } }

    .screen { position: relative; min-height: 100vh; background: var(--bg); color: var(--fg); overflow-x: hidden; transition: background .5s ease, color .5s ease; }
    .layer { position: relative; z-index: 1; }
    #ripplecanvas { position: fixed; inset: 0; z-index: 0; pointer-events: none; }
    #curring { position: fixed; top: 0; left: 0; width: 30px; height: 30px; margin: -15px 0 0 -15px; border: 1px solid var(--accent); border-radius: 50%; z-index: 60; pointer-events: none; opacity: 0; transition: opacity .3s ease; will-change: transform; mix-blend-mode: difference; }
    #curdot { position: fixed; top: 0; left: 0; width: 6px; height: 6px; margin: -3px 0 0 -3px; background: var(--accent); border-radius: 50%; z-index: 61; pointer-events: none; opacity: 0; transition: opacity .3s ease; will-change: transform; }

    header.topbar { position: fixed; top: 0; left: 0; right: 0; z-index: 40; display: flex; align-items: center; justify-content: space-between; padding: 24px clamp(28px, 5vw, 72px); color: var(--fg); transition: color .5s ease; }
    header.topbar .brand { font-family: 'JetBrains Mono', monospace; font-size: 13px; letter-spacing: 0.02em; }
    header.topbar .topbar-actions { display: flex; align-items: center; gap: clamp(16px, 3vw, 28px); }
    header.topbar .lang { color: var(--fg2); text-decoration: none; font-family: 'JetBrains Mono', monospace; font-size: 13px; letter-spacing: 0.08em; transition: color .25s ease; }
    header.topbar .lang:hover { color: var(--accent); }
    header.topbar button { cursor: pointer; background: none; border: none; color: var(--fg); font-family: 'JetBrains Mono', monospace; font-size: 13px; letter-spacing: 0.04em; display: flex; align-items: center; gap: 8px; }
    header.topbar .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); display: inline-block; animation: blink 2.4s infinite; }

    .hero { min-height: 100vh; display: flex; flex-direction: column; padding: 0 clamp(28px, 5vw, 72px); max-width: 1480px; margin: 0 auto; }
    .hero-row { flex: 1; display: flex; align-items: center; gap: clamp(40px, 6vw, 88px); padding-top: 128px; padding-bottom: 72px; }
    .hero-head { flex: 1; min-width: 0; }
    .hero h1 { font-weight: 700; font-size: clamp(60px, 9.5vw, 138px); line-height: 0.9; letter-spacing: -0.045em; margin: 0; color: var(--fg); }
    .hero h1 [data-accent] { color: var(--accent); }
    .hero-meta { width: 236px; flex: none; border-left: 1px solid var(--line); padding-left: 28px; display: flex; flex-direction: column; gap: 26px; font-family: 'JetBrains Mono', monospace; font-size: 12px; line-height: 1.6; }
    .hero-meta .meta-label { color: var(--fg3); letter-spacing: 0.12em; }
    .hero-meta .meta-value { color: var(--fg); margin-top: 6px; }
    .hero-meta .meta-link { color: var(--fg); margin-top: 6px; text-decoration: none; display: inline-block; transition: color .25s ease; }
    .hero-meta .meta-link:hover { color: var(--accent); }
    .scroll-explore { align-self: flex-start; padding-bottom: 40px; display: inline-flex; flex-direction: column; align-items: center; gap: 16px; text-decoration: none; color: var(--fg2); font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.2em; transition: color .25s ease; }
    .scroll-explore:hover { color: var(--accent); }
    .scroll-explore .chevrons { display: flex; flex-direction: column; align-items: center; gap: 7px; height: 34px; }
    .scroll-explore .chevrons span { width: 12px; height: 12px; border-right: 2px solid var(--accent); border-bottom: 2px solid var(--accent); animation: chevFall 1.5s ease-in-out infinite; }
    .scroll-explore .chevrons span:nth-child(2) { animation-delay: 0.18s; }
    .scroll-explore .chevrons span:nth-child(3) { animation-delay: 0.36s; }
    @media (max-width: 760px) {
      .hero-row { flex-direction: column; align-items: flex-start; gap: 40px; padding-top: 120px; }
      .hero-meta { width: 100%; border-left: none; border-top: 1px solid var(--line); padding-left: 0; padding-top: 26px; }
    }

    .index { max-width: 1480px; margin: 0 auto; padding: 40px clamp(28px, 5vw, 72px) 80px; }
    .index .label { font-family: 'JetBrains Mono', monospace; font-size: 13px; color: var(--fg2); letter-spacing: 0.04em; margin-bottom: 8px; border-bottom: 1px solid var(--line); padding-bottom: 22px; }
    .index .entry { display: flex; align-items: baseline; justify-content: space-between; gap: 24px; text-decoration: none; color: var(--fg); border-bottom: 1px solid var(--line); padding: clamp(20px, 3.4vw, 42px) 0; transition: color .3s ease; }
    .index .entry:hover { color: var(--accent); }
    .index .entry .left { display: flex; align-items: baseline; gap: clamp(14px, 2.5vw, 38px); min-width: 0; }
    .index .entry .num { font-family: 'JetBrains Mono', monospace; font-size: clamp(11px, 1.3vw, 14px); color: var(--fg3); flex-shrink: 0; }
    .index .entry .name { font-weight: 600; font-size: clamp(34px, 7.5vw, 92px); line-height: 0.95; letter-spacing: -0.03em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .index .entry .year { font-family: 'JetBrains Mono', monospace; font-size: clamp(11px, 1.3vw, 14px); color: var(--fg3); flex-shrink: 0; white-space: nowrap; }

    .channel { max-width: 1480px; margin: 0 auto; padding: 90px clamp(28px, 5vw, 72px) 70px; }
    .channel .label { font-family: 'JetBrains Mono', monospace; font-size: 13px; color: var(--fg2); letter-spacing: 0.04em; margin-bottom: 30px; }
    .channel .signed { margin-top: 48px; display: flex; align-items: center; gap: 14px; font-family: 'JetBrains Mono', monospace; font-size: 13px; color: var(--fg3); flex-wrap: wrap; }
    .channel .signed .lbl { color: var(--fg2); }
    .channel .signed .cipher { color: var(--accent); letter-spacing: 0.1em; }

    footer.site { border-top: 1px solid var(--line); max-width: 1480px; margin: 0 auto; padding: 24px clamp(28px, 5vw, 72px); display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--fg3); }

    /* project "window" — full-page animated takeover */
    .fullwin { position: fixed; inset: 0; z-index: 90; background: var(--bg); color: var(--fg); overflow-y: auto;
      visibility: hidden; opacity: 0;
      clip-path: circle(0px at var(--ox, 50%) var(--oy, 50%));
      transition: clip-path .72s cubic-bezier(.76, 0, .24, 1), opacity .25s ease .32s, visibility 0s linear .72s; }
    .fullwin.open { visibility: visible; opacity: 1; clip-path: circle(var(--r, 150vmax) at var(--ox, 50%) var(--oy, 50%));
      transition: clip-path .72s cubic-bezier(.76, 0, .24, 1), opacity .2s ease, visibility 0s; }
    .fw-canvas { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
    .fw-bar { position: sticky; top: 0; z-index: 2; display: flex; align-items: center; gap: 12px; padding: 22px clamp(28px, 5vw, 72px); border-bottom: 1px solid var(--line); background: color-mix(in oklab, var(--bg) 84%, transparent); -webkit-backdrop-filter: blur(7px); backdrop-filter: blur(7px); }
    .fw-bar .win-dots { display: flex; gap: 7px; }
    .fw-bar .win-dots i { width: 11px; height: 11px; border-radius: 50%; background: var(--line); display: inline-block; }
    .fw-bar .win-dots i:first-child { background: var(--accent); }
    .fw-addr { font-family: 'JetBrains Mono', monospace; font-size: 13px; color: var(--fg3); letter-spacing: 0.04em; }
    .fw-close { margin-left: auto; display: flex; align-items: center; gap: 8px; background: none; border: none; cursor: pointer; color: var(--fg2); font-family: 'JetBrains Mono', monospace; font-size: 13px; letter-spacing: 0.06em; transition: color .2s ease; }
    .fw-close:hover { color: var(--accent); }
    .fw-inner { position: relative; z-index: 1; max-width: 1100px; margin: 0 auto; padding: clamp(48px, 12vh, 150px) clamp(28px, 5vw, 72px) 110px; }
    .fw-meta { display: flex; gap: 18px; font-family: 'JetBrains Mono', monospace; font-size: 13px; color: var(--fg3); letter-spacing: 0.08em; }
    .fw-name { font-weight: 700; font-size: clamp(46px, 11vw, 140px); line-height: 0.95; letter-spacing: -0.04em; margin-top: 18px; color: var(--fg); }
    .fw-brief { margin-top: 34px; color: var(--fg2); font-size: clamp(16px, 2.2vw, 24px); line-height: 1.5; max-width: 60ch; }
    .fw-stack-label { margin-top: 54px; font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.14em; color: var(--fg3); }
    .fw-stack { margin-top: 16px; display: flex; flex-wrap: wrap; gap: 10px; }
    .fw-chip { font-family: 'JetBrains Mono', monospace; font-size: 13px; color: var(--fg2); border: 1px solid var(--line); border-radius: 999px; padding: 9px 16px; }
    .fw-open { margin-top: 54px; display: inline-flex; align-items: center; gap: 8px; font-family: 'JetBrains Mono', monospace; font-size: 14px; letter-spacing: 0.04em; color: var(--ink); background: var(--accent); text-decoration: none; padding: 16px 28px; border-radius: 10px; font-weight: 500; transition: filter .2s ease; }
    .fw-open:hover { filter: brightness(1.08); }
    /* staggered content reveal once the panel has opened */
    .fullwin .fw-inner > * { opacity: 0; transform: translateY(26px); transition: opacity .55s ease, transform .55s cubic-bezier(.2, .9, .25, 1); }
    .fullwin.open .fw-inner > * { opacity: 1; transform: none; }
    .fullwin.open .fw-inner > *:nth-child(1) { transition-delay: .30s; }
    .fullwin.open .fw-inner > *:nth-child(2) { transition-delay: .36s; }
    .fullwin.open .fw-inner > *:nth-child(3) { transition-delay: .42s; }
    .fullwin.open .fw-inner > *:nth-child(4) { transition-delay: .48s; }
    .fullwin.open .fw-inner > *:nth-child(5) { transition-delay: .54s; }
    .fullwin.open .fw-inner > *:nth-child(6) { transition-delay: .60s; }
    @media (prefers-reduced-motion: reduce) {
      .fullwin, .fullwin.open { clip-path: none; transition: opacity .2s ease, visibility 0s; }
      .fullwin .fw-inner > * { transition: none; transform: none; opacity: 1; }
    }
  </style>
</body>
</html>
