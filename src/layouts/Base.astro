---
import type { Lang } from '../i18n/strings';
import { strings } from '../i18n/strings';
import { projects, contactEmail } from '../data/projects';

interface Props {
  lang: Lang;
  /** Path of THIS page relative to the site root, e.g. '/' or '/tr/'. */
  path: string;
}

const { lang, path } = Astro.props;
const t = strings[lang];

const site = 'https://alpsenel.com';
const canonical = new URL(path, site).href;
const enUrl = new URL('/', site).href;
const trUrl = new URL('/tr/', site).href;
const ogImage = new URL('/og.png', site).href;

// Person + WebSite structured data — the name lives here for search engines,
// even though it is intentionally never shown in the visible page body.
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': `${site}/#person`,
      name: 'Alp Senel',
      url: site,
      jobTitle: lang === 'tr' ? 'Web Geliştirici & Tasarımcı' : 'Web Developer & Designer',
      knowsAbout: ['Web Development', 'Web Design', 'E-commerce', 'Shopify', 'Frontend Engineering'],
    },
    {
      '@type': 'WebSite',
      '@id': `${site}/#website`,
      url: site,
      name: 'Alp Senel',
      inLanguage: t.htmlLang,
      publisher: { '@id': `${site}/#person` },
    },
  ],
};

// Per-language project payload for the client (powers the "window" modal).
const clientProjects = projects.map((p) => ({
  num: p.num,
  name: p.name,
  year: p.year,
  url: p.url,
  handle: p.handle,
  tech: p.tech,
  brief: p.brief[lang],
}));
---

<!DOCTYPE html>
<html lang={t.htmlLang} data-theme="dark" data-accent="lime">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{t.title}</title>
  <meta name="description" content={t.description} />
  <meta name="author" content="Alp Senel" />
  <link rel="canonical" href={canonical} />

  <!-- hreflang: tell Google about both language versions -->
  <link rel="alternate" hreflang="en" href={enUrl} />
  <link rel="alternate" hreflang="tr" href={trUrl} />
  <link rel="alternate" hreflang="x-default" href={enUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Alp Senel" />
  <meta property="og:title" content={t.title} />
  <meta property="og:description" content={t.description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content={t.ogLocale} />
  <meta property="og:locale:alternate" content={t.ogLocaleAlt} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={t.title} />
  <meta name="twitter:description" content={t.description} />
  <meta name="twitter:image" content={ogImage} />

  <meta name="theme-color" content="#0c0e12" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/favicon.svg" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  />

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</head>
<body>
  <div class="screen">
    <canvas id="ripplecanvas"></canvas>
    <div id="curring"></div>
    <div id="curdot"></div>

    <div class="layer">
      <!-- top bar -->
      <header class="topbar">
        <span class="brand">{t.brand}</span>
        <div class="topbar-actions">
          <a class="lang" data-cursor href={t.otherLangHref} hreflang={lang === 'en' ? 'tr' : 'en'} aria-label="Change language">{t.otherLangLabel}</a>
          <button data-cursor id="themeToggle" aria-label="Toggle theme">
            <span class="dot"></span><span id="themeLabel">{t.lightsOn}</span>
          </button>
        </div>
      </header>

      <!-- HERO -->
      <section class="hero">
        <div class="kicker">{t.kicker}</div>
        <h1 set:html={t.h1html} />
        <div class="scrollhint" set:html={t.scrollhint} />
      </section>

      <!-- INDEX -->
      <section class="index">
        <div class="label">{t.workLabel}</div>
        {projects.map((p, i) => (
          <a class="entry" href={p.url} target="_blank" rel="noopener" data-cursor data-reveal data-index={i}>
            <span class="left">
              <span class="num">{p.num}</span>
              <span class="name">{p.name}</span>
            </span>
            <span class="year">{p.year} ↗</span>
          </a>
        ))}
      </section>

      <!-- CHANNEL -->
      <section class="channel">
        <div class="label">{t.channelLabel}</div>
        <a data-cursor class="signal" href={`mailto:${contactEmail}`}>{t.signal}</a>
        <div class="signed">
          <span class="lbl">{t.signed}</span>
          <span class="cipher" id="cipher">█▓█▓██▓█▓</span>
        </div>
      </section>

      <footer class="site">
        <span>{t.footLeft}</span>
        <span>{t.footRight}</span>
      </footer>
    </div>
  </div>

  <!-- project "window" modal -->
  <div id="proj-modal" class="modal" aria-hidden="true">
    <div class="modal-backdrop" data-close></div>
    <div class="modal-window" role="dialog" aria-modal="true" aria-labelledby="modal-name">
      <div class="win-bar">
        <span class="win-dots"><i></i><i></i><i></i></span>
        <span class="win-addr" id="modal-addr">anon://</span>
        <button class="win-close" data-close type="button" aria-label={t.closeLabel}>✕</button>
      </div>
      <div class="win-body">
        <div class="win-meta"><span id="modal-num"></span><span id="modal-year"></span></div>
        <h2 class="win-name" id="modal-name"></h2>
        <div class="win-brief-label">{t.briefLabel}</div>
        <p class="win-brief" id="modal-brief"></p>
        <div class="win-stack-label">{t.stackLabel}</div>
        <div class="win-stack" id="modal-stack"></div>
        <a class="win-open" id="modal-open" href="#" target="_blank" rel="noopener">{t.openLive}</a>
      </div>
    </div>
  </div>

  <script type="application/json" id="projects-data" set:html={JSON.stringify(clientProjects)} />

  <script
    is:inline
    define:vars={{ lightsOn: t.lightsOn, lightsOff: t.lightsOff }}
  >
    // ---- theme toggle ----
    (function () {
      const root = document.documentElement;
      const label = document.getElementById('themeLabel');
      const syncLabel = function () {
        label.textContent = root.getAttribute('data-theme') === 'dark' ? lightsOn : lightsOff;
      };
      syncLabel();
      document.getElementById('themeToggle').addEventListener('click', function () {
        root.setAttribute('data-theme', root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
        syncLabel();
      });

      // ---- project "window" modal ----
      (function () {
        const modal = document.getElementById('proj-modal');
        const dataEl = document.getElementById('projects-data');
        if (!modal || !dataEl) return;
        let data = [];
        try { data = JSON.parse(dataEl.textContent); } catch (e) { return; }

        const elNum = document.getElementById('modal-num');
        const elYear = document.getElementById('modal-year');
        const elName = document.getElementById('modal-name');
        const elAddr = document.getElementById('modal-addr');
        const elBrief = document.getElementById('modal-brief');
        const elStack = document.getElementById('modal-stack');
        const elOpen = document.getElementById('modal-open');
        let lastFocus = null;

        function open(idx) {
          const p = data[idx];
          if (!p) return;
          elNum.textContent = p.num;
          elYear.textContent = p.year;
          elName.textContent = p.name;
          elAddr.textContent = 'anon://' + p.handle;
          elBrief.textContent = p.brief;
          elOpen.href = p.url;
          elStack.innerHTML = '';
          p.tech.forEach(function (techName) {
            const chip = document.createElement('span');
            chip.className = 'win-chip';
            chip.textContent = techName;
            elStack.appendChild(chip);
          });
          lastFocus = document.activeElement;
          modal.classList.add('open');
          modal.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';
          elOpen.focus();
        }
        function close() {
          modal.classList.remove('open');
          modal.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
          if (lastFocus && lastFocus.focus) lastFocus.focus();
        }

        document.querySelectorAll('.index .entry').forEach(function (el) {
          el.addEventListener('click', function (e) {
            // let modified clicks (new tab / middle) fall through to the real link
            if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey || e.button !== 0) return;
            e.preventDefault();
            open(parseInt(el.getAttribute('data-index'), 10));
          });
        });
        modal.querySelectorAll('[data-close]').forEach(function (el) {
          el.addEventListener('click', close);
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && modal.classList.contains('open')) close();
        });
      })();

      // ---- self-scrambling signature — never resolves ----
      const charset = '█▓▒░#@%&$?/\\*+=<>0123456789ABCDEFGHJKLMNPQRSTUVWXYZ'.split('');
      const cipherEl = document.getElementById('cipher');
      setInterval(function () {
        let s = '';
        for (let i = 0; i < 11; i++) s += charset[Math.floor(Math.random() * charset.length)];
        cipherEl.textContent = s;
      }, 110);

      // ---- scroll reveal ----
      (function () {
        const els = document.querySelectorAll('[data-reveal]');
        els.forEach(function (el) {
          el.style.opacity = '0';
          el.style.transform = 'translateY(26px)';
          el.style.transition = 'opacity .8s ease, transform .8s ease';
        });
        if ('IntersectionObserver' in window) {
          const io = new IntersectionObserver(function (ents) {
            ents.forEach(function (e) {
              if (e.isIntersecting) {
                e.target.style.opacity = '1';
                e.target.style.transform = 'none';
                io.unobserve(e.target);
              }
            });
          }, { threshold: 0.2 });
          els.forEach(function (el) { io.observe(el); });
          setTimeout(function () {
            els.forEach(function (el) { el.style.opacity = '1'; el.style.transform = 'none'; });
          }, 2600);
        } else {
          els.forEach(function (el) { el.style.opacity = '1'; el.style.transform = 'none'; });
        }
      })();

      // ---- cursor follow + water-surface ripple FX ----
      // A height-field water simulation (damped wave equation). Pointer moves
      // and clicks drop disturbances that spread, interfere and fade like
      // ripples on a dark pool, lit from the top-left with an accent sheen.
      (function () {
        const canvas = document.getElementById('ripplecanvas');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        const host = document.querySelector('.screen');
        const dot = document.getElementById('curdot');
        const ring = document.getElementById('curring');
        const fine = window.matchMedia('(pointer:fine)').matches;
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        const SCALE = 6;      // px per simulation cell
        const DAMP = 0.967;   // wave energy retained per frame (higher = waves travel further)
        let cols, rows, cur, prev, off, offCtx, img, accent = [163, 230, 53];

        function resolveAccent() {
          try {
            offCtx.fillStyle = getComputedStyle(host).getPropertyValue('--accent').trim() || '#a3e635';
            offCtx.fillRect(0, 0, 1, 1);
            const d = offCtx.getImageData(0, 0, 1, 1).data;
            accent = [d[0], d[1], d[2]];
          } catch (e) {}
        }

        function setup() {
          cols = Math.max(8, Math.ceil(window.innerWidth / SCALE));
          rows = Math.max(8, Math.ceil(window.innerHeight / SCALE));
          cur = new Float32Array(cols * rows);
          prev = new Float32Array(cols * rows);
          off = document.createElement('canvas');
          off.width = cols; off.height = rows;
          offCtx = off.getContext('2d', { willReadFrequently: true });
          img = offCtx.createImageData(cols, rows);
          canvas.width = window.innerWidth; canvas.height = window.innerHeight;
          canvas.style.width = window.innerWidth + 'px'; canvas.style.height = window.innerHeight + 'px';
          resolveAccent();
        }
        setup();
        window.addEventListener('resize', setup);

        // drop a soft, radius-stamped disturbance so the rings stay circular
        function drop(px, py, power) {
          const cx = Math.round(px / SCALE), cy = Math.round(py / SCALE), rad = 2;
          for (let y = -rad; y <= rad; y++) {
            for (let x = -rad; x <= rad; x++) {
              const gx = cx + x, gy = cy + y;
              if (gx < 1 || gy < 1 || gx >= cols - 1 || gy >= rows - 1) continue;
              const d = Math.sqrt(x * x + y * y);
              if (d > rad) continue;
              prev[gy * cols + gx] -= power * (1 - d / rad);
            }
          }
        }

        // ---- cursor dot + ring follow ----
        let mx = window.innerWidth / 2, my = window.innerHeight / 2, rx = mx, ry = my, lx = mx, ly = my;
        let hover = false;
        if (fine) {
          host.style.cursor = 'none';
          if (dot) dot.style.opacity = '1';
          if (ring) ring.style.opacity = '1';
        }
        window.addEventListener('pointermove', function (e) {
          mx = e.clientX; my = e.clientY;
          if (dot) dot.style.transform = 'translate(' + mx + 'px,' + my + 'px)';
          const dx = mx - lx, dy = my - ly, dist2 = dx * dx + dy * dy;
          if (dist2 > 90) { drop(mx, my, Math.min(1.3 + dist2 * 0.0012, 3.8)); lx = mx; ly = my; }
        }, { passive: true });
        window.addEventListener('pointerdown', function (e) { drop(e.clientX, e.clientY, 9); }, { passive: true });

        document.querySelectorAll('[data-cursor]').forEach(function (el) {
          el.addEventListener('pointerenter', function () { hover = true; });
          el.addEventListener('pointerleave', function () { hover = false; });
        });

        // gentle ambient drips so the surface always breathes
        let ambient = 60;
        function maybeAmbient() {
          if (reduce) return;
          if (--ambient <= 0) {
            ambient = 80 + Math.floor(Math.random() * 120);
            drop(Math.random() * window.innerWidth, Math.random() * window.innerHeight, 2.0);
          }
        }

        function tick() {
          rx += (mx - rx) * 0.16; ry += (my - ry) * 0.16;
          if (ring) ring.style.transform = 'translate(' + rx + 'px,' + ry + 'px) scale(' + (hover ? 2.2 : 1) + ')';

          maybeAmbient();

          // propagate the wave field
          for (let y = 1; y < rows - 1; y++) {
            const r = y * cols;
            for (let x = 1; x < cols - 1; x++) {
              const i = r + x;
              cur[i] = ((prev[i - 1] + prev[i + 1] + prev[i - cols] + prev[i + cols]) * 0.5 - cur[i]) * DAMP;
            }
          }
          const tmp = cur; cur = prev; prev = tmp; // prev now holds the newest field

          // render height field as light on water
          const data = img.data, ar = accent[0], ag = accent[1], ab = accent[2];
          for (let y = 1; y < rows - 1; y++) {
            const r = y * cols;
            for (let x = 1; x < cols - 1; x++) {
              const i = r + x;
              const h = prev[i];
              const spec = Math.max(0, (prev[i - 1] - prev[i + 1]) * 0.7 + (prev[i - cols] - prev[i + cols]) * 0.9);
              let a = Math.abs(h) * 62 + spec * 46; if (a > 255) a = 255;
              let sp = spec * 150; if (sp > 255) sp = 255;
              const p = i * 4;
              data[p] = ar + sp > 255 ? 255 : ar + sp;
              data[p + 1] = ag + sp > 255 ? 255 : ag + sp;
              data[p + 2] = ab + sp > 255 ? 255 : ab + sp;
              data[p + 3] = a;
            }
          }
          offCtx.putImageData(img, 0, 0);
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          ctx.imageSmoothingEnabled = true;
          ctx.drawImage(off, 0, 0, canvas.width, canvas.height);

          requestAnimationFrame(tick);
        }
        tick();
      })();
    })();
  </script>

  <style is:global>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    :root {
      --bg: oklch(0.155 0.012 256); --bg2: oklch(0.205 0.013 256);
      --line: oklch(0.30 0.012 256); --fg: oklch(0.965 0.004 256); --fg2: oklch(0.66 0.012 256); --fg3: oklch(0.46 0.012 256);
      --accent: oklch(0.87 0.17 132); --ink: oklch(0.16 0.02 256);
    }
    [data-theme="light"] {
      --bg: oklch(0.975 0.004 256); --bg2: oklch(0.945 0.006 256);
      --line: oklch(0.88 0.006 256); --fg: oklch(0.205 0.013 256); --fg2: oklch(0.46 0.012 256); --fg3: oklch(0.64 0.01 256);
    }
    [data-accent="cyan"] { --accent: oklch(0.83 0.13 218); }
    [data-accent="violet"] { --accent: oklch(0.78 0.15 292); }
    [data-accent="coral"] { --accent: oklch(0.77 0.16 32); }
    body { background: var(--bg); color: var(--fg); font-family: 'Space Grotesk', sans-serif; -webkit-font-smoothing: antialiased; }
    ::selection { background: var(--accent); color: var(--ink); }
    @keyframes blink { 0%, 100% { opacity: .4; } 50% { opacity: 1; } }

    .screen { position: relative; min-height: 100vh; background: var(--bg); color: var(--fg); overflow-x: hidden; transition: background .5s ease, color .5s ease; }
    .layer { position: relative; z-index: 1; }
    #ripplecanvas { position: fixed; inset: 0; z-index: 0; pointer-events: none; }
    #curring { position: fixed; top: 0; left: 0; width: 30px; height: 30px; margin: -15px 0 0 -15px; border: 1px solid var(--accent); border-radius: 50%; z-index: 60; pointer-events: none; opacity: 0; transition: opacity .3s ease; will-change: transform; mix-blend-mode: difference; }
    #curdot { position: fixed; top: 0; left: 0; width: 6px; height: 6px; margin: -3px 0 0 -3px; background: var(--accent); border-radius: 50%; z-index: 61; pointer-events: none; opacity: 0; transition: opacity .3s ease; will-change: transform; }

    header.topbar { position: fixed; top: 0; left: 0; right: 0; z-index: 40; display: flex; align-items: center; justify-content: space-between; padding: 24px clamp(20px, 4vw, 44px); color: var(--fg); transition: color .5s ease; }
    header.topbar .brand { font-family: 'JetBrains Mono', monospace; font-size: 13px; letter-spacing: 0.02em; }
    header.topbar .topbar-actions { display: flex; align-items: center; gap: clamp(16px, 3vw, 28px); }
    header.topbar .lang { color: var(--fg2); text-decoration: none; font-family: 'JetBrains Mono', monospace; font-size: 13px; letter-spacing: 0.08em; transition: color .25s ease; }
    header.topbar .lang:hover { color: var(--accent); }
    header.topbar button { cursor: pointer; background: none; border: none; color: var(--fg); font-family: 'JetBrains Mono', monospace; font-size: 13px; letter-spacing: 0.04em; display: flex; align-items: center; gap: 8px; }
    header.topbar .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); display: inline-block; animation: blink 2.4s infinite; }

    .hero { min-height: 100vh; display: flex; flex-direction: column; justify-content: center; padding: 120px clamp(20px, 4vw, 44px) 80px; max-width: 1300px; margin: 0 auto; }
    .hero .kicker { font-family: 'JetBrains Mono', monospace; font-size: 13px; color: var(--fg2); letter-spacing: 0.04em; margin-bottom: 34px; }
    .hero h1 { font-weight: 700; font-size: clamp(52px, 12vw, 150px); line-height: 0.92; letter-spacing: -0.04em; }
    .hero h1 .accent { color: var(--accent); }
    .hero .scrollhint { margin-top: auto; padding-top: 80px; font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--fg3); letter-spacing: 0.08em; }

    .index { max-width: 1300px; margin: 0 auto; padding: 40px clamp(20px, 4vw, 44px) 80px; }
    .index .label { font-family: 'JetBrains Mono', monospace; font-size: 13px; color: var(--fg2); letter-spacing: 0.04em; margin-bottom: 8px; border-bottom: 1px solid var(--line); padding-bottom: 22px; }
    .index .entry { display: flex; align-items: baseline; justify-content: space-between; gap: 24px; text-decoration: none; color: var(--fg); border-bottom: 1px solid var(--line); padding: clamp(20px, 3.4vw, 42px) 0; transition: color .3s ease; }
    .index .entry:hover { color: var(--accent); }
    .index .entry .left { display: flex; align-items: baseline; gap: clamp(14px, 2.5vw, 38px); min-width: 0; }
    .index .entry .num { font-family: 'JetBrains Mono', monospace; font-size: clamp(11px, 1.3vw, 14px); color: var(--fg3); flex-shrink: 0; }
    .index .entry .name { font-weight: 600; font-size: clamp(34px, 7.5vw, 92px); line-height: 0.95; letter-spacing: -0.03em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .index .entry .year { font-family: 'JetBrains Mono', monospace; font-size: clamp(11px, 1.3vw, 14px); color: var(--fg3); flex-shrink: 0; white-space: nowrap; }

    .channel { max-width: 1300px; margin: 0 auto; padding: 90px clamp(20px, 4vw, 44px) 70px; }
    .channel .label { font-family: 'JetBrains Mono', monospace; font-size: 13px; color: var(--fg2); letter-spacing: 0.04em; margin-bottom: 30px; }
    .channel a.signal { display: inline-block; text-decoration: none; color: var(--fg); font-weight: 600; font-size: clamp(34px, 7vw, 84px); letter-spacing: -0.03em; line-height: 1; transition: color .3s ease; }
    .channel a.signal:hover { color: var(--accent); }
    .channel .signed { margin-top: 48px; display: flex; align-items: center; gap: 14px; font-family: 'JetBrains Mono', monospace; font-size: 13px; color: var(--fg3); flex-wrap: wrap; }
    .channel .signed .lbl { color: var(--fg2); }
    .channel .signed .cipher { color: var(--accent); letter-spacing: 0.1em; }

    footer.site { border-top: 1px solid var(--line); max-width: 1300px; margin: 0 auto; padding: 24px clamp(20px, 4vw, 44px); display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--fg3); }

    /* project "window" modal */
    .modal { position: fixed; inset: 0; z-index: 80; display: none; align-items: center; justify-content: center; padding: 24px; }
    .modal.open { display: flex; }
    .modal-backdrop { position: absolute; inset: 0; background: color-mix(in oklab, var(--bg) 62%, transparent); -webkit-backdrop-filter: blur(7px); backdrop-filter: blur(7px); opacity: 0; transition: opacity .35s ease; }
    .modal.open .modal-backdrop { opacity: 1; }
    .modal-window { position: relative; width: min(580px, 94vw); max-height: 88vh; overflow: auto; background: var(--bg2); border: 1px solid var(--line); border-radius: 14px; box-shadow: 0 40px 90px rgba(0,0,0,.55); transform: scale(.9) translateY(14px); opacity: 0; transition: transform .42s cubic-bezier(.2,.9,.25,1), opacity .3s ease; }
    .modal.open .modal-window { transform: none; opacity: 1; }
